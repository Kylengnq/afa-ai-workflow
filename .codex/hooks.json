{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/session_start.py\"",
            "timeout": 10,
            "statusMessage": "Preparing AFA session logging"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/log_turn.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/compile_latex_after_edit.py\"",
            "timeout": 60,
            "statusMessage": "Compiling LaTeX to PDF..."
          }
        ],
        "matcher": "Edit|Write|apply_patch"
      }
    ]
  }
}
